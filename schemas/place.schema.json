{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["id"],
  "anyOf": [
    { "required": ["name"] },
    { "required": ["display_name"] }
  ],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "summary": { "type": "string" },
    "traits": { "type": "array", "items": { "type": "string" } },
    "aliases": { "type": "array", "items": { "type": "string" } },
    "display_name": { "type": "string" },
    "type": { "type": "string" },
    "region": { "type": "string" },
    "tone": { "type": "array", "items": { "type": "string" } },
    "long_description": { "type": "string" },
    "default_scene": { "type": "string" },
    "sublocations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "display_name"],
        "properties": {
          "id": { "type": "string" },
          "display_name": { "type": "string" }
        }
      }
    },
    "spice_lines": { "type": "array", "items": { "type": "string" } },
    "ambient_profiles": { "type": "array", "items": { "type": "string" } },
    "event_overlays": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "text"],
        "properties": {
          "id": { "type": "string" },
          "text": { "type": "string" }
        }
      }
    },
    "micro_encounters": { "type": "array", "items": { "type": "string" } },
    "monster_table": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "weight"],
        "properties": {
          "id": { "type": "string" },
          "weight": { "type": "number" },
          "when": { "type": "object" }
        }
      }
    },
    "wildlife_table": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "weight"],
        "properties": {
          "id": { "type": "string" },
          "weight": { "type": "number" },
          "when": { "type": "object" }
        }
      }
    },
    "home_npcs": { "type": "array", "items": { "type": "string" } },
    "npc_whitelist": { "type": "array", "items": { "type": "string" } },
    "usage_notes": { "type": "object" }
  }
}
